//@version=6
// Universal Strategy — Any Market / Her Piyasa
// github.com/trugurpala/pinescriptv6 — Author: Ugur Pala
//
// TR: Bu strateji herhangi bir enstrümanda çalışacak şekilde tasarlandı.
//     syminfo.* değişkenleri ile otomatik uyum sağlar.
// EN: This strategy adapts automatically to any instrument.
//     Uses syminfo.* variables for automatic adaptation.
strategy("Universal Strategy [trugurpala]",
    overlay           = true,
    initial_capital   = 10000,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 5,
    commission_type   = strategy.commission.percent,
    commission_value  = 0.1,
    slippage          = 2)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   fastLen   = input.int(9,    "Fast EMA",      minval=1)
int   slowLen   = input.int(21,   "Slow EMA",      minval=1)
int   trendLen  = input.int(50,   "Trend EMA",     minval=1)
int   atrLen    = input.int(14,   "ATR",           minval=1)
float slMult    = input.float(1.5, "SL ATR Mult",  step=0.1)
float tpMult    = input.float(2.5, "TP ATR Mult",  step=0.1)
bool  longOnly  = input.bool(false, "Long Only")
bool  useTrend  = input.bool(true,  "Use Trend Filter")

// ── Hesaplamalar ──────────────────────────────────────────────────────────────
float fastEma   = ta.ema(close, fastLen)
float slowEma   = ta.ema(close, slowLen)
float trendEma  = ta.ema(close, trendLen)
float atrVal    = ta.atr(atrLen)

bool trendUp    = not useTrend or close > trendEma
bool trendDown  = not useTrend or close < trendEma
bool bullCross  = ta.crossover(fastEma, slowEma) and trendUp
bool bearCross  = ta.crossunder(fastEma, slowEma) and trendDown

// ── Debug: Enstrüman Bilgisi / Instrument Info ────────────────────────────────
if barstate.islast
    label.new(bar_index, high,
        syminfo.exchange + ":" + syminfo.ticker + "\n" +
        "Type: " + syminfo.type + "\n" +
        "Currency: " + syminfo.currency + "\n" +
        "Mintick: " + str.tostring(syminfo.mintick),
        style     = label.style_label_down,
        color     = color.new(color.blue, 70),
        textcolor = color.white,
        size      = size.small)

// ── Entries ──────────────────────────────────────────────────────────────────
if bullCross
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long",
        stop=close - slMult*atrVal, limit=close + tpMult*atrVal)
if bearCross and not longOnly
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short",
        stop=close + slMult*atrVal, limit=close - tpMult*atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(fastEma,  "Fast",  fastEma > slowEma ? color.green : color.red,   linewidth=2)
plot(slowEma,  "Slow",  fastEma > slowEma ? color.lime  : color.orange,linewidth=2)
plot(trendEma, "Trend", color.new(color.gray, 40),                     linewidth=1)
bgcolor(bullCross[1] ? color.new(color.green, 95) : bearCross[1] ? color.new(color.red, 95) : na)
plotshape(bullCross, "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(bearCross, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
