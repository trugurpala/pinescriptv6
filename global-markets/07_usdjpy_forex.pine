//@version=6
// USD/JPY Forex Strategy — Tokyo + London Session
// github.com/trugurpala/pinescriptv6 — Author: Ugur Pala
//
// TR: Sembol: FX:USDJPY
// EN: Symbol: FX:USDJPY
// Tokyo: 00:00–09:00 GMT | London: 08:00–16:00 GMT
// Not: BOJ müdahaleleri ve faiz kararlarına dikkat
// Note: Watch for BOJ interventions and rate decisions
strategy("USD/JPY Forex Strategy [trugurpala]",
    overlay           = true,
    initial_capital   = 10000,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 2,
    commission_type   = strategy.commission.percent,
    commission_value  = 0.005,
    slippage          = 1)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   fastLen  = input.int(9,    "Fast EMA",  minval=1)
int   slowLen  = input.int(21,   "Slow EMA",  minval=1)
int   atrLen   = input.int(14,   "ATR",       minval=1)
float slMult   = input.float(1.5, "SL Mult",  step=0.1)
float tpMult   = input.float(2.5, "TP Mult",  step=0.1)

// ── Tokyo + London Seans ──────────────────────────────────────────────────────
bool tokyo   = not na(time(timeframe.period, "0000-0900", "GMT"))
bool london  = not na(time(timeframe.period, "0800-1600", "GMT"))
bool inSes   = tokyo or london

// ── Hesaplamalar ──────────────────────────────────────────────────────────────
float fastEma = ta.ema(close, fastLen)
float slowEma = ta.ema(close, slowLen)
float atrVal  = ta.atr(atrLen)
bool bullCross = ta.crossover(fastEma, slowEma) and inSes
bool bearCross = ta.crossunder(fastEma, slowEma) and inSes

// ── Entries ──────────────────────────────────────────────────────────────────
if bullCross
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close-slMult*atrVal, limit=close+tpMult*atrVal)
if bearCross
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close+slMult*atrVal, limit=close-tpMult*atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
bgcolor(tokyo and london ? color.new(color.purple, 93) :
        inSes            ? color.new(color.blue,   96) :
                           color.new(color.gray,   97))
plot(fastEma, "Fast", fastEma > slowEma ? color.green : color.red,    linewidth=2)
plot(slowEma, "Slow", fastEma > slowEma ? color.lime  : color.orange, linewidth=2)
plotshape(bullCross, "Long",  shape.triangleup,   location.belowbar, color.green)
plotshape(bearCross, "Short", shape.triangledown, location.abovebar, color.red)
