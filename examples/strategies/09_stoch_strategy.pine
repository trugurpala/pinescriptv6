//@version=6
// Stochastic Cross + EMA Filter — github.com/trugurpala/pinescriptv6
// Author: Ugur Pala · mail@ugurpala.com
strategy("Stoch Strategy [trugurpala]",
    overlay=true, initial_capital=10000,
    default_qty_type=strategy.percent_of_equity, default_qty_value=10,
    commission_type=strategy.commission.percent, commission_value=0.1)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   stochLen = input.int(14, "Stoch Length", minval=1)
int   kSmooth  = input.int(3,  "K Smooth",     minval=1)
int   dSmooth  = input.int(3,  "D Smooth",     minval=1)
float obLevel  = input.float(80, "OB", minval=60, maxval=95)
float osLevel  = input.float(20, "OS", minval=5,  maxval=40)
int   emaLen   = input.int(200, "Filter EMA",  minval=1)
int   atrLen   = input.int(14,  "ATR Length",  minval=1)
float slMult   = input.float(1.5, "SL Mult",   step=0.1)
float tpMult   = input.float(2.5, "TP Mult",   step=0.1)

// ── Calculations ─────────────────────────────────────────────────────────────
[kRaw, _]  = ta.stoch(high, low, close, stochLen), ta.stoch(high, low, close, stochLen)
[kLine, dLine] = ta.stoch(high, low, close, stochLen), ta.stoch(high, low, close, stochLen)
float k      = ta.sma(ta.stoch(high, low, close, stochLen), kSmooth)
float d      = ta.sma(k, dSmooth)
float emaVal = ta.ema(close, emaLen)
float atrVal = ta.atr(atrLen)
bool  longEntry  = ta.crossover(k, d)  and k < osLevel and close > emaVal
bool  shortEntry = ta.crossunder(k, d) and k > obLevel and close < emaVal

// ── Entries ──────────────────────────────────────────────────────────────────
if longEntry
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)
if shortEntry
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(emaVal, "EMA Filter", color.new(color.orange, 20), linewidth=2)
plotshape(longEntry,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
