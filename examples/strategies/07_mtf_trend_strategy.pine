//@version=6
// Multi-Timeframe Trend Strategy — github.com/trugurpala/pinescriptv6
// Author: Ugur Pala · mail@ugurpala.com
strategy("MTF Trend Strategy [trugurpala]",
    overlay=true, initial_capital=10000,
    default_qty_type=strategy.percent_of_equity, default_qty_value=10,
    commission_type=strategy.commission.percent, commission_value=0.1)

// ── Inputs ───────────────────────────────────────────────────────────────────
string htfInput   = input.string("D", "Higher TF", options=["60","240","D","W"])
int    htfEmaLen  = input.int(21, "HTF EMA", minval=1)
int    fastLen    = input.int(9,  "Fast EMA", minval=1)
int    slowLen    = input.int(21, "Slow EMA", minval=1)
int    atrLen     = input.int(14, "ATR", minval=1)
float  slMult     = input.float(1.5, "SL Mult", step=0.1)
float  tpMult     = input.float(2.5, "TP Mult", step=0.1)

// ── Higher Timeframe (no repainting) ─────────────────────────────────────────
float htfEma   = request.security(syminfo.tickerid, htfInput, ta.ema(close, htfEmaLen)[1], lookahead=barmerge.lookahead_on)
float htfClose = request.security(syminfo.tickerid, htfInput, close[1], lookahead=barmerge.lookahead_on)
bool  htfBull   = htfClose > htfEma
bool  htfBear   = htfClose < htfEma

// ── Lower Timeframe ──────────────────────────────────────────────────────────
float fastEma  = ta.ema(close, fastLen)
float slowEma  = ta.ema(close, slowLen)
float atrVal   = ta.atr(atrLen)
bool  bullCross = ta.crossover(fastEma,  slowEma) and htfBull
bool  bearCross = ta.crossunder(fastEma, slowEma) and htfBear

// ── Entries ──────────────────────────────────────────────────────────────────
if bullCross
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)
if bearCross
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(fastEma, "Fast", color.green, linewidth=2)
plot(slowEma, "Slow", color.red,   linewidth=2)
plot(htfEma,  "HTF EMA", color.new(color.orange, 20), linewidth=3)
bgcolor(htfBull ? color.new(color.green, 95) : color.new(color.red, 95))
plotshape(bullCross, "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(bearCross, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
