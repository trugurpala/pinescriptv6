//@version=6
// Triple EMA 5/13/34 Alignment Strategy — github.com/trugurpala/pinescriptv6
// Author: Ugur Pala · mail@ugurpala.com
strategy("Triple EMA Strategy [trugurpala]",
    overlay=true, initial_capital=10000,
    default_qty_type=strategy.percent_of_equity, default_qty_value=10,
    commission_type=strategy.commission.percent, commission_value=0.1)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   e1Len  = input.int(5,  "EMA 1", minval=1)
int   e2Len  = input.int(13, "EMA 2", minval=1)
int   e3Len  = input.int(34, "EMA 3", minval=1)
int   atrLen = input.int(14, "ATR",   minval=1)
float slMult = input.float(1.5, "SL Mult", step=0.1)
float tpMult = input.float(2.5, "TP Mult", step=0.1)

// ── Calculations ─────────────────────────────────────────────────────────────
float ema1   = ta.ema(close, e1Len)
float ema2   = ta.ema(close, e2Len)
float ema3   = ta.ema(close, e3Len)
float atrVal = ta.atr(atrLen)
bool  bullAlign  = ema1 > ema2 and ema2 > ema3
bool  bearAlign  = ema1 < ema2 and ema2 < ema3
bool  prevBull   = ema1[1] > ema2[1] and ema2[1] > ema3[1]
bool  prevBear   = ema1[1] < ema2[1] and ema2[1] < ema3[1]
bool  longEntry  = bullAlign and not prevBull
bool  shortEntry = bearAlign and not prevBear

// ── Entries ──────────────────────────────────────────────────────────────────
if longEntry
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)
if shortEntry
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)
if strategy.position_size > 0 and not bullAlign
    strategy.close("Long")
if strategy.position_size < 0 and not bearAlign
    strategy.close("Short")

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(ema1, "EMA 5",  bullAlign ? color.green : bearAlign ? color.red    : color.gray, linewidth=1)
plot(ema2, "EMA 13", bullAlign ? color.lime  : bearAlign ? color.orange : color.gray, linewidth=2)
plot(ema3, "EMA 34", bullAlign ? color.teal  : bearAlign ? color.maroon : color.gray, linewidth=3)
bgcolor(bullAlign ? color.new(color.green, 94) : bearAlign ? color.new(color.red, 94) : na)
