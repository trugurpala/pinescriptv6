//@version=6
// VİOP Session Strategy — BIST30 Futures Seans Bazlı
// github.com/trugurpala/pinescriptv6 — Author: Ugur Pala
strategy("VİOP Session Strategy [trugurpala]",
    overlay           = true,
    initial_capital   = 10000,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 10,
    commission_type   = strategy.commission.percent,
    commission_value  = 0.03,
    slippage          = 2)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   fastLen  = input.int(9,    "Fast EMA",   minval=1)
int   slowLen  = input.int(21,   "Slow EMA",   minval=1)
int   atrLen   = input.int(14,   "ATR",        minval=1)
float slMult   = input.float(2.0, "SL Mult",   step=0.1)
float tpMult   = input.float(3.0, "TP Mult",   step=0.1)
bool  longOnly = input.bool(false, "Long Only")

// ── VİOP Seans Filtresi: 09:30 - 18:15 UTC+3 ─────────────────────────────────
bool inSession = not na(time(timeframe.period, "0930-1815", "UTC+3"))
bool sesOpen   = inSession and not inSession[1]   // Seans açılışı

// ── Gün kapanışta tüm pozisyonları kapat ─────────────────────────────────────
bool sesClose  = not inSession and inSession[1]   // Seans kapanışı
if sesClose
    strategy.close_all(comment="Seans sonu / End of session")

// ── Calculations ─────────────────────────────────────────────────────────────
float fastEma = ta.ema(close, fastLen)
float slowEma = ta.ema(close, slowLen)
float atrVal  = ta.atr(atrLen)

bool bullCross = ta.crossover(fastEma,  slowEma) and inSession
bool bearCross = ta.crossunder(fastEma, slowEma) and inSession

// ── Entries ──────────────────────────────────────────────────────────────────
if bullCross
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long",
        stop  = close - slMult * atrVal,
        limit = close + tpMult * atrVal)

if bearCross and not longOnly
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short",
        stop  = close + slMult * atrVal,
        limit = close - tpMult * atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
bgcolor(inSession  ? color.new(color.blue,  96) : color.new(color.gray, 97))
plot(fastEma, "Fast", fastEma > slowEma ? color.green : color.red,    linewidth=2)
plot(slowEma, "Slow", fastEma > slowEma ? color.lime  : color.orange, linewidth=2)
plotshape(bullCross, "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(bearCross, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
