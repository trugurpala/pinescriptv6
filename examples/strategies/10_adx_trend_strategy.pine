//@version=6
// ADX Trend Strength + EMA Strategy — github.com/trugurpala/pinescriptv6
// Author: Ugur Pala · mail@ugurpala.com
strategy("ADX Trend Strategy [trugurpala]",
    overlay=true, initial_capital=10000,
    default_qty_type=strategy.percent_of_equity, default_qty_value=10,
    commission_type=strategy.commission.percent, commission_value=0.1)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   adxLen   = input.int(14, "ADX Length",  minval=1)
float adxMin   = input.float(25, "ADX Min",   minval=10, maxval=50)
int   fastLen  = input.int(9,  "Fast EMA",    minval=1)
int   slowLen  = input.int(21, "Slow EMA",    minval=1)
int   atrLen   = input.int(14, "ATR Length",  minval=1)
float slMult   = input.float(1.5, "SL Mult",  step=0.1)
float tpMult   = input.float(2.5, "TP Mult",  step=0.1)

// ── Calculations ─────────────────────────────────────────────────────────────
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
float fastEma    = ta.ema(close, fastLen)
float slowEma    = ta.ema(close, slowLen)
float atrVal     = ta.atr(atrLen)
bool  trendStrong = adxVal >= adxMin
bool  bullCross   = ta.crossover(fastEma,  slowEma) and trendStrong and diPlus > diMinus
bool  bearCross   = ta.crossunder(fastEma, slowEma) and trendStrong and diMinus > diPlus

// ── Entries ──────────────────────────────────────────────────────────────────
if bullCross
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)
if bearCross
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(fastEma, "Fast", fastEma > slowEma ? color.green : color.red,    linewidth=2)
plot(slowEma, "Slow", fastEma > slowEma ? color.lime  : color.orange, linewidth=2)
plotshape(bullCross, "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(bearCross, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
