//@version=6
// RSI + ATR Dynamic SL/TP — Optimized for VIOP/BIST30
// github.com/trugurpala/pinescriptv6 — Author: Ugur Pala
strategy("RSI + ATR Strategy [trugurpala]",
    overlay=true, initial_capital=10000,
    default_qty_type=strategy.percent_of_equity, default_qty_value=10,
    commission_type=strategy.commission.percent, commission_value=0.03,
    slippage=2)

// ── Inputs ───────────────────────────────────────────────────────────────────
int   rsiLen   = input.int(14, "RSI Length",  minval=1)
float rsiOb    = input.float(60, "RSI Long Min", minval=50, maxval=80)
float rsiOs    = input.float(40, "RSI Short Max", minval=20, maxval=50)
int   trendLen = input.int(50,  "Trend EMA",  minval=1)
int   atrLen   = input.int(14,  "ATR Length", minval=1)
float slMult   = input.float(2.0, "SL Mult",  step=0.1)
float tpMult   = input.float(3.0, "TP Mult",  step=0.1)

// ── Calculations ─────────────────────────────────────────────────────────────
float rsi      = ta.rsi(close, rsiLen)
float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)
bool  longEntry  = rsi > rsiOb and close > trendEma and strategy.position_size == 0
bool  shortEntry = rsi < rsiOs and close < trendEma and strategy.position_size == 0

// ── Entries ──────────────────────────────────────────────────────────────────
if longEntry
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)
if shortEntry
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(trendEma, "Trend EMA", color.orange, linewidth=2)
plotshape(longEntry,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)
